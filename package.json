{
  "name": "fusekit-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "mprocs",
    "web:dev": "pnpm --filter @fusekit/web dev",
    "build": "pnpm --filter @fusekit/web build",
    "start": "pnpm --filter @fusekit/web start",
    "lint": "pnpm --filter @fusekit/web lint",
    "db:seed": "cd services/platform && ../../.venv/bin/python -m app.db_init",
    "db:migrate": "cd infra && ../.venv/bin/alembic upgrade head",
    "db:migration:create": "cd infra && ../.venv/bin/alembic revision --autogenerate -m",
    "setup": "python3 -m venv .venv && .venv/bin/python -m pip install -e services/platform && .venv/bin/python -m pip install -e services/integrator && pnpm install"
  }
}
