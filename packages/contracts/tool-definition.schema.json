{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ToolDefinition",
  "description": "Single canonical shape for a tool. Used by MCP server, catalog API, and integration pipeline.",
  "type": "object",
  "required": ["name", "description", "provider", "cost_per_call", "status", "input_schema"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Snake_case identifier. Unique across the catalog."
    },
    "description": {
      "type": "string",
      "description": "Plain-English description shown to Codex."
    },
    "provider": { "type": "string" },
    "cost_per_call": { "type": "integer", "minimum": 1 },
    "status": {
      "type": "string",
      "enum": ["live", "pending_credentials", "deprecated"]
    },
    "input_schema": { "type": "object" },
    "output_schema": { "type": "object" },
    "category": {
      "type": "string",
      "enum": ["communication", "data_retrieval", "search", "payments", "productivity", "other"]
    },
    "source": { "type": "string", "enum": ["manual", "pipeline", "seed"] },
    "version": { "type": "integer", "minimum": 1 },
    "implementation_module": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
